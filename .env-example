# Common == Change this if you want to replace db b/w sqlite and postgres
# sqlite or postgres (see config.py for settings code)
# DB_ENGINE=sqlite
DB_ENGINE=postgres  # or sqlite (see config.py)

# SQLite DB settings
SQLITE_FILE_NAME=database.db

# POSTGRES db settings
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=fastapi_architecture_db # first should be created in pgadmin locally

# DeepSeek API settings
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_SECONDS=60

# OpenRouter API settings
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-oss-120b:free
OPENROUTER_CLAUDE_MODEL=anthropic/claude-3-haiku
OPENROUTER_TIMEOUT_SECONDS=60
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=FastAPI Clean Architecture
