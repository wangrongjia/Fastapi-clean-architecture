# Test APIs
# Using REST Client vscode extension - allows you to send HTTP request 
# and view the response in Visual Studio Code directly.

### POST Request
POST http://localhost:8000/heroes HTTP/1.1
Content-Type: application/json

{
  "name": "string5-alembic",
  "age": 5,
  "secret_name": "string5",
  "gender": "Male"
}

### GET many
GET http://localhost:8000/heroes?offset=0&limit=100 HTTP/1.1

### GET many - curl request (copied from http://127.0.0.1:8000/docs#/)
curl -X 'GET' \
  'http://127.0.0.1:8000/heroes/?offset=0&limit=100' \
  -H 'accept: application/json'

### GET one
GET http://localhost:8000/heroes/3 HTTP/1.1

### PATCH - update a hero
PATCH http://localhost:8000/heroes/2 HTTP/1.1
Content-Type: application/json

{
  "age": 22
}


### DELETE a hero
DELETE http://localhost:8000/heroes/1 HTTP/1.1

### Chat with DeepSeek
POST http://localhost:8000/chat/deepseek HTTP/1.1
Content-Type: application/json

{
  "messages": [
    {
      "role": "system",
      "content": "You are a helpful assistant."
    },
    {
      "role": "user",
      "content": "你好，简单介绍一下 FastAPI。"
    }
  ],
  "thinking_enabled": false
}

### Chat with OpenRouter gpt-oss-120b free
POST http://localhost:8000/chat/openrouter HTTP/1.1
Content-Type: application/json

{
  "messages": [
    {
      "role": "system",
      "content": "You are a helpful assistant."
    },
    {
      "role": "user",
      "content": "Explain FastAPI in two short sentences."
    }
  ],
  "temperature": 0.7,
  "reasoning_effort": "low"
}

### Chat with OpenRouter Claude 3 Haiku
POST http://localhost:8000/chat/openrouter/claude HTTP/1.1
Content-Type: application/json

{
  "messages": [
    {
      "role": "system",
      "content": "You are a helpful assistant."
    },
    {
      "role": "user",
      "content": "Explain FastAPI in two short sentences."
    }
  ],
  "temperature": 0.7,
  "max_tokens": 128
}

### Stream chat with OpenRouter Claude 3 Haiku
POST http://localhost:8000/chat/openrouter/claude/stream HTTP/1.1
Content-Type: application/json
Accept: text/event-stream

{
  "messages": [
    {
      "role": "user",
      "content": "Explain FastAPI in two short sentences."
    }
  ],
  "temperature": 0.7,
  "max_tokens": 128
}

### Stream chat with OpenRouter gpt-oss-120b free
POST http://localhost:8000/chat/openrouter/stream HTTP/1.1
Content-Type: application/json
Accept: text/event-stream

{
  "messages": [
    {
      "role": "user",
      "content": "Explain FastAPI in two short sentences."
    }
  ],
  "temperature": 0.7,
  "reasoning_effort": "low"
}

# The stream response includes a final usage chunk before data: [DONE]
# because the server sends stream_options.include_usage=true.

### Stream chat with DeepSeek
POST http://localhost:8000/chat/deepseek/stream HTTP/1.1
Content-Type: application/json
Accept: text/event-stream

{
  "messages": [
    {
      "role": "user",
      "content": "用三句话介绍 FastAPI。"
    }
  ],
  "thinking_enabled": false
}
